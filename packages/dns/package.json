{
  "name": "@tcpip/dns",
  "version": "0.2.1",
  "description": "DNS server built on tcpip.js",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup --clean",
    "clean": "rm -rf dist",
    "test": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "files": ["dist/**/*"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "@tcpip/wire": "workspace:*"
  },
  "devDependencies": {
    "@total-typescript/tsconfig": "catalog:",
    "tcpip": "workspace:*",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
