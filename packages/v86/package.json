{
  "name": "@tcpip/v86",
  "version": "0.2.1",
  "description": "Network adapter that connects tcpip.js with v86",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsup --clean",
    "clean": "rm -rf dist",
    "test": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "files": ["dist/**/*"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.cjs"
    }
  },
  "devDependencies": {
    "@tcpip/wire": "workspace:*",
    "@total-typescript/tsconfig": "catalog:",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "v86": "^0.5.44",
    "vitest": "catalog:"
  }
}
